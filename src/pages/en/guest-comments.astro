---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { dbRun } from '../../db/client';

let successMessage = '';
let errorMessage = '';

const { id: postId } = Astro.params; 

if (Astro.request.method === 'POST') {
    try {
        const formData = await Astro.request.formData();
        const name = formData.get('name')?.toString().trim();
        const level = formData.get('level')?.toString();
        const content = formData.get('message')?.toString().trim();
        const formPostId = formData.get('postId')?.toString() || postId || 'default-post-id';
        const rating = formData.get('rating')?.toString();

        if (name && content && formPostId && level && rating && rating !== '0') {
           await dbRun(
               'INSERT INTO comments (id, author, content, post_id, level, rating, created_at) VALUES (?, ?, ?, ?, ?, ?, ?)',
               [crypto.randomUUID(), name, content, formPostId, level, parseInt(rating), Date.now()]
           );
           
           successMessage = 'Thank you for your comment! It has been submitted successfully.';
        } else {
            errorMessage = 'Please fill out all required fields and rate your trip.';
        }
    } catch (error) {
        console.error("الخطأ الحقيقي هو:", error);
        errorMessage = 'Something went wrong. Please try again.';
    }
}
---

<Layout title="Guest comments | Scuba Adventures">
  <main class="max-w-2xl mx-auto my-12 p-6 bg-slate-900 rounded-xl shadow-2xl text-white border border-slate-800">
    
    <h1 class="text-3xl md:text-4xl font-bold mb-8 text-center" style="color: #ecca0ad2; font-family: inherit;">
      We would love to hear about your experience with us!
    </h1>
    
    <section class="comment-form-section">
      <h2 class="text-xl font-semibold mb-6 text-slate-300 border-b border-slate-800 pb-2">Leave a Comment</h2>
        {successMessage && <p class="text-green-500 mb-4">{successMessage}</p>}
        {errorMessage && <p class="text-red-500 mb-4">{errorMessage}</p>}
      
      <form id="comment-form" method="POST" data-astro-reload class="flex flex-col gap-5">
        <input type="hidden" name="postId" value={postId} />
        
        <div class="flex flex-col gap-2">
          <label for="guest-name" class="font-medium text-slate-300">Your Name</label>
          <input 
            type="text" 
            id="guest-name" 
            name="name" 
            required 
            placeholder="Enter your name" 
            class="w-full px-4 py-2.5 bg-slate-800 border border-slate-700 rounded-lg text-white placeholder-slate-500 focus:outline-none focus:border-yellow-500 focus:ring-1 focus:ring-yellow-500 transition-all"
          />
        </div>

        <div class="flex flex-col gap-2">
          <label for="guest-level" class="font-medium text-slate-300">Select your level</label>
          <select 
            id="guest-level" 
            name="level" 
            required 
            class="w-full px-4 py-2.5 bg-slate-800 border border-slate-700 rounded-lg text-white focus:outline-none focus:border-yellow-500 focus:ring-1 focus:ring-yellow-500 transition-all cursor-pointer"
          >
            <option value="" disabled selected hidden>Select your level</option>
            <option value="discovery">Discovery Scuba Diving</option>
            <option value="open-water">Open Water Diver</option>
            <option value="advanced">Advanced Open Water</option>
            <option value="rescue">Rescue Diver</option>
            <option value="divemaster">Divemaster</option>
            <option value="instructor">Instructor & Above</option>
          </select>
        </div>
        
        <div class="flex flex-col gap-2">
          <label for="guest-message" class="font-medium text-slate-300">Your Comment</label>
          <textarea 
            id="guest-message" 
            name="message" 
            rows="4" 
            required 
            placeholder="Share your experience..." 
            class="w-full px-4 py-2.5 bg-slate-800 border border-slate-700 rounded-lg text-white placeholder-slate-500 focus:outline-none focus:border-yellow-500 focus:ring-1 focus:ring-yellow-500 transition-all resize-none"
          ></textarea>
        </div>

        <div class="my-4 text-center bg-slate-800/50 p-4 rounded-lg border border-slate-800">
          <label class="block text-lg font-medium mb-2 text-slate-300">Rate Your Trip:</label>
          <div class="flex justify-center gap-2 text-4xl mb-2">
            <span class="star cursor-pointer transition-colors duration-200" data-value="1" style="color: #4b5563;">★</span>
            <span class="star cursor-pointer transition-colors duration-200" data-value="2" style="color: #4b5563;">★</span>
            <span class="star cursor-pointer transition-colors duration-200" data-value="3" style="color: #4b5563;">★</span>
            <span class="star cursor-pointer transition-colors duration-200" data-value="4" style="color: #4b5563;">★</span>
            <span class="star cursor-pointer transition-colors duration-200" data-value="5" style="color: #4b5563;">★</span>
          </div>
          <div id="rating-text" class="text-base font-bold min-h-[24px]" style="color: #ecca0ad2;"></div>
          <input type="hidden" name="rating" id="rating-input" value="0" />
        </div>

        <button 
          type="submit" 
          class="w-full py-3 px-6 bg-yellow-600 hover:bg-yellow-500 text-slate-950 font-bold rounded-lg shadow-lg hover:shadow-yellow-600/20 transition-all duration-200 cursor-pointer active:scale-[0.99]"
        >
          Submit Comment
        </button>
      </form>
      {successMessage && (
         <div class="my-4 text-center text-green-500 font-semibold">
         <p>{successMessage}</p>
         <a href="/" class="mt-4 inline-block px-4 py-2 bg-yellow-600 hover:bg-yellow-500 text-slate-950 font-bold rounded-lg">Go to Home</a>
        </div> )} 
    </section>

    <hr class="my-8 border-slate-800" />
    
    <section class="comments-display-section">
      {/* هنا بيتم عرض الكومنتات لاحقاً */}
    </section>
  </main>
</Layout>

<script is:inline>
  const stars = document.querySelectorAll('.star');
  const ratingText = document.getElementById('rating-text');
  const ratingInput = document.getElementById('rating-input');
  const form = document.getElementById('comment-form');

  const labels = {
    1: "Bad 😞",
    2: "Acceptable 😐",
    3: "Good 🙂",
    4: "Very Good 😃",
    5: "Excellent! 🤩"
  };

  // التحكم في اختيار النجوم
  stars.forEach(star => {
    star.addEventListener('click', () => {
      const value = parseInt(star.getAttribute('data-value'));
      ratingInput.value = value;
      ratingText.textContent = labels[value];
      
      stars.forEach(s => {
        const sValue = parseInt(s.getAttribute('data-value'));
        if (sValue <= value) {
          s.style.color = '#ecca0ad2';
        } else {
          s.style.color = '#4b5563';
        }
      });
    });
  });

  // حماية إضافية: منع إرسال الفورم لو المستخدم مأختارش نجوم
  form.addEventListener('submit', (e) => {
    if (ratingInput.value === '0' || !ratingInput.value) {
      e.preventDefault();
      alert('Please select a star rating before submitting your comment!');
    }
  });
</script>