---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="Terms of Service" description="Scuba Academy terms of service.">
  <section class="pt-28 pb-16 bg-background">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 space-y-6">
      <h1 class="text-4xl font-bold">Terms of Service</h1>
      <p class="text-text-secondary">These demo terms will be replaced with final legal text. Bookings are subject to availability and safety requirements.</p>
      <p class="text-text-secondary">Certification courses are delivered by licensed instructors. Refunds are handled according to our cancellation policy.</p>
    </div>
  </section>
</MainLayout>
