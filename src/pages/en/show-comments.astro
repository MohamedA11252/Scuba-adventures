---
export const prerender = false;
import { db } from '../../db/client'; 

// الجزء ده عشان يلقط لو دوست على زرار المسح ويمسح الكومنت من الداتا بيز
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const deleteId = formData.get('deleteId')?.toString();
    
    if (deleteId && db) {
       (db as any).prepare('DELETE FROM comments WHERE id = ?').run(deleteId);
    }
  } catch (error) {
    console.error("Error deleting comment:", error);
  }
}

let comments: any[] = [];
if (db) {
  comments = (db as any).prepare('SELECT * FROM comments ORDER BY id DESC').all() || [];
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Guest Comments</title>
    <style>
      /* شوية ستايل سريع عشان العين تشوفه حلو */
      .comments-container { max-width: 600px; margin: 40px auto; font-family: sans-serif; }
      .comment-card { 
        border: 1px solid #ddd; 
        padding: 15px; 
        margin-bottom: 15px; 
        border-radius: 8px; 
        background-color: #f9f9f9; 
        position: relative; /* ضفناها عشان نظبط مكان زرار المسح */
      }
      .comment-author { font-weight: bold; color: #333; }
      .comment-date { font-size: 0.8rem; color: #666; margin-bottom: 8px; }
      
      /* ستايل زرار المسح الأحمر */
      .delete-btn {
        background-color: #dc2626; 
        color: white;
        border: none;
        border-radius: 4px;
        width: 30px;
        height: 30px;
        font-weight: bold;
        font-size: 16px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background-color 0.2s;
      }
      .delete-btn:hover {
        background-color: #b91c1c; 
      }
      .delete-form {
        position: absolute;
        top: 15px;
        right: 15px;
        margin: 0;
      }
    </style>
  </head>
  <body>

    <div class="comments-container">
      <h2>SIR "AboSaid" HERE IS YOUR GUEST COMMENTS </h2>

      {comments.length === 0 ? (
        <p>مفيش أي تعليقات اتكتبت لسه!</p>
      ) : (
        comments.map((comment) => (
          <div class="comment-card"> 
            
            {/* فورم المسح اللي جواه الزرار الأحمر ورسالة التأكيد */}
            <form 
              method="POST" 
              class="delete-form"
              onsubmit="return confirm('Are you sure that you want to delete this message?');"
            >
              <input type="hidden" name="deleteId" value={comment.id} />
              <button type="submit" class="delete-btn" title="Delete Comment">X</button>
            </form>

            <div class="comment-author">Name: {comment.author}</div>
            <div class="comment-level">Level: {comment.level}</div>
            <p class="comment-text">Comment: {comment.content}</p>
            <div class="comment-rating">Rating: {comment.rating}</div>
            <div class="comment-date">Date: {new Date(comment.created_at).toLocaleString('en-US')}</div>
          </div>
        ))
      )}
    </div>

  </body>
</html>