---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="Privacy Policy" description="Scuba Academy privacy policy.">
  <section class="pt-28 pb-16 bg-background">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 space-y-6">
      <h1 class="text-4xl font-bold">Privacy Policy</h1>
      <p class="text-text-secondary">We respect your privacy and handle your data with care. This is demo content and will be updated with legal copy.</p>
      <p class="text-text-secondary">We collect minimal data required to provide booking and account services. You can request data deletion at any time.</p>
    </div>
  </section>
</MainLayout>
