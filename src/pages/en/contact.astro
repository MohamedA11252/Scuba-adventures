---
import MainLayout from '../../layouts/MainLayout.astro';
import Card from '../../components/ui/Card.astro';
import Input from '../../components/ui/Input.astro';
import Button from '../../components/ui/Button.astro';
---

<MainLayout title="Contact Us" description="Get in touch with Scuba Academy.">
  <section class="pt-28 pb-16 bg-background" data-animate="fade-up">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold">Contact Us</h1>
        <p class="text-lg text-text-secondary mt-3">We respond within 24 hours for all inquiries.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        <Card>
          <h2 class="text-2xl font-semibold mb-4">Speak with our team</h2>
          <p class="text-text-secondary">WhatsApp: +20 114 596 4916</p>
          <p class="text-text-secondary">WhatsApp: +20 100 288 7702</p>
          <p class="text-text-secondary mt-4">Hurghada, Egypt</p>
        </Card>
        <Card>
          <h2 class="text-2xl font-semibold mb-4">Send a message</h2>
          <form class="space-y-4">
            <div>
              <label for="name" class="text-sm text-text-secondary">Name</label>
              <Input id="name" name="name" placeholder="Your name" />
            </div>
            <div>
              <label for="email" class="text-sm text-text-secondary">Email</label>
              <Input id="email" name="email" type="email" placeholder="you@example.com" />
            </div>
            <div>
              <label for="message" class="text-sm text-text-secondary">Message</label>
              <textarea id="message" name="message" rows="4" class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-secondary focus:border-secondary transition-colors"></textarea>
            </div>
            <Button>Send Message</Button>
          </form>
        </Card>
      </div>
    </div>
  </section>
</MainLayout>
