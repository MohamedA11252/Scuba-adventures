---
import MainLayout from '../../layouts/MainLayout.astro';
import CourseCard from '../../components/features/CourseCard.astro';
import { getCourses } from '../../lib/catalog';
import { getLangFromPathname, getTranslations } from '../../lib/i18n';
import { BRAND_NAME } from '../../lib/brand';

const lang = getLangFromPathname(Astro.url.pathname);
const t = getTranslations(lang);
const courses = getCourses();

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: `${BRAND_NAME} Courses`,
    itemListElement: courses.map((course, index) => ({
      "@type": "ListItem",
      position: index + 1,
      item: {
        "@type": "Course",
        name: course.title,
        description: course.shortDescription,
        provider: { "@type": "Organization", name: BRAND_NAME }
      }
    }))
};
---

<MainLayout title={t.courses.title} description={t.courses.description}>
  <section class="pt-28 pb-16 bg-background" data-animate="fade-up">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold">{t.courses.heading}</h1>
        <p class="text-lg text-text-secondary mt-3">{t.courses.subtitle}</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {courses.map(course => (
          <CourseCard course={course} bookLabel={t.courses.bookNow} dateLabel={t.courses.selectDate} lang={lang} />
        ))}
      </div>
    </div>
  </section>
</MainLayout>

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
