---
import Card from '../ui/Card.astro';
import { getTranslations } from '../../lib/i18n';

interface Props {
  course: {
    id: string;
    title: string;
    shortDescription: string;
    difficulty: string;
    price: number;
    durationDays: number;
    seats: number;
    certification: string;
    instructor: string;
    nextStart: string;
    image: string;
  };
  bookLabel?: string;
  dateLabel?: string;
  lang?: string;
}

const { course, bookLabel, dateLabel, lang = "en" } = Astro.props;
const t = getTranslations(lang);
const label = bookLabel || t.courses.bookNow;
const dLabel = dateLabel || t.courses.selectDate;
const dayLabel = course.durationDays === 1 ? t.courses.day : t.courses.days;
---

<Card className="overflow-hidden card-hover border border-gray-200/50 hover:border-ocean-muted/50">
  <a href={`/${lang}/courses/${course.id}`} class="block">
    <div class="h-48 w-full">
      <img src={course.image} alt={course.title} class="h-full w-full object-cover" loading="lazy" />
    </div>
  </a>
  <div class="mt-6 space-y-3">
    <div class="flex items-center justify-between">
      <h3 class="text-xl font-semibold text-gradient">{course.title}</h3>
      <span class="text-sm text-ocean-muted font-medium">{course.certification}</span>
    </div>
    <p class="text-text-secondary">{course.shortDescription}</p>
    <div class="grid grid-cols-2 gap-4 text-sm text-text-secondary">
      <span>{t.courses.difficulty}: <span class="font-medium text-primary">{course.difficulty}</span></span>
      <span>{t.courses.duration}: <span class="font-medium text-primary">{course.durationDays} {dayLabel}</span></span>
      <span>{t.courses.seats}: <span class="font-medium text-primary">{course.seats}</span></span>
      <span>{t.courses.instructor}: <span class="font-medium text-primary">{course.instructor}</span></span>
      <span>{t.courses.nextStart}: <span class="font-medium text-primary">{course.nextStart}</span></span>
    </div>
    <div class="flex items-center justify-between pt-4 border-t border-gray-200/50">
      <span class="text-2xl font-bold text-ocean-dark">€{course.price}</span>
      <a href={`/${lang}/contact`} class="inline-flex items-center justify-center rounded-md font-semibold transition-all focus:outline-none focus:ring-2 focus:ring-offset-2 bg-secondary text-white hover:bg-ocean-muted ring-secondary px-4 py-2 text-sm">{label}</a>
    </div>
  </div>
</Card>
