---
import Card from '../ui/Card.astro';

interface Props {
  testimonial: {
    name: string;
    role: string;
    quote: string;
  };
}

const { testimonial } = Astro.props;
---

<Card>
  <p class="text-text-secondary italic">"{testimonial.quote}"</p>
  <div class="mt-6">
    <p class="text-primary font-semibold">{testimonial.name}</p>
    <p class="text-sm text-text-secondary">{testimonial.role}</p>
  </div>
</Card>
