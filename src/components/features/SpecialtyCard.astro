---
import Card from '../ui/Card.astro';
import { getTranslations } from '../../lib/i18n';

interface Props {
  specialty: {
    id: string;
    title: string;
    shortDescription: string;
    difficulty: string;
    price: number;
    durationDays: number;
    certification: string;
    equipment: string;
    image: string;
  };
  lang?: string;
}

const { specialty, lang = "en" } = Astro.props;
const t = getTranslations(lang);
const dayLabel = specialty.durationDays === 1 ? t.specialties.day : t.specialties.days;
---

<Card className="overflow-hidden card-hover border border-gray-200/50 hover:border-ocean-muted/50">
  <a href={`/${lang}/specialties/${specialty.id}`} class="block">
    <div class="h-48 w-full">
      <img src={specialty.image} alt={specialty.title} class="h-full w-full object-cover" loading="lazy" />
    </div>
  </a>
  <div class="mt-6 space-y-3">
    <div class="flex items-center justify-between">
      <h3 class="text-xl font-semibold text-gradient">{specialty.title}</h3>
      <span class="text-sm text-ocean-muted font-medium">{specialty.certification}</span>
    </div>
    <p class="text-text-secondary">{specialty.shortDescription}</p>
    <div class="grid grid-cols-2 gap-4 text-sm text-text-secondary">
      <span>{t.specialties.difficulty}: <span class="font-medium text-primary">{specialty.difficulty}</span></span>
      <span>{t.specialties.duration}: <span class="font-medium text-primary">{specialty.durationDays} {dayLabel}</span></span>
      <span>{t.specialties.equipment}: <span class="font-medium text-primary">{specialty.equipment}</span></span>
    </div>
    <div class="flex items-center justify-between pt-4 border-t border-gray-200/50">
      <span class="text-2xl font-bold text-ocean-dark">€{specialty.price}</span>
      <a href={`/${lang}/contact`} class="inline-flex items-center justify-center rounded-md font-semibold transition-all focus:outline-none focus:ring-2 focus:ring-offset-2 bg-secondary text-white hover:bg-ocean-muted ring-secondary px-4 py-2 text-sm">{t.common.bookNow}</a>
    </div>
  </div>
</Card>
