---
interface Props {
  experience: {
    id: string;
    title: string;
    description: string;
    shortDescription: string;
    includes: string[];
    excludes: string[];
    price: number;
    durationHours: number;
    maxDivers: number;
    image: string;
  };
  bookLabel?: string;
}

const { experience, bookLabel = "Book Now" } = Astro.props;
---

<div class="bg-surface border border-gray-200/50 rounded-xl overflow-hidden shadow-premium hover:shadow-lg transition-shadow">
  <div class="relative h-64 overflow-hidden">
    <img src={experience.image} alt={experience.title} class="w-full h-full object-cover" loading="lazy" />
  </div>
  <div class="p-6">
    <h3 class="text-2xl font-bold text-primary mb-2">{experience.title}</h3>
    <p class="text-text-secondary mb-4">{experience.shortDescription}</p>
    
    <div class="space-y-4 mb-6">
      <div class="flex items-center gap-2 text-sm text-text-secondary">
        <span class="font-semibold">Duration:</span>
        <span>{experience.durationHours} hours</span>
      </div>
      <div class="flex items-center gap-2 text-sm text-text-secondary">
        <span class="font-semibold">Max Divers:</span>
        <span>{experience.maxDivers} people</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="text-2xl font-bold text-primary">${experience.price}</span>
        <span class="text-sm text-text-secondary">per person</span>
      </div>
    </div>

    <div class="mb-6">
      <h4 class="text-sm font-semibold text-primary mb-3">What's Included:</h4>
      <ul class="space-y-2">
        {experience.includes.map((item) => (
          <li class="flex items-start gap-2 text-sm text-text-secondary">
            <span class="text-accent mt-1">✓</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="mb-6">
      <h4 class="text-sm font-semibold text-primary mb-3">What's Excluded:</h4>
      <ul class="space-y-2">
        {experience.excludes.map((item) => (
          <li class="flex items-start gap-2 text-sm text-text-secondary">
            <span class="text-accent">−</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>

    <button class="w-full bg-secondary text-white py-3 rounded-md font-semibold hover:bg-opacity-90 transition-colors">
      {bookLabel}
    </button>
  </div>
</div>
