---
import Card from '../ui/Card.astro';
import BookingButton from '../ui/BookingButton.astro';

interface Props {
  trip: {
    id: string;
    title: string;
    description: string;
    price: number;
    durationDays: number;
    seats: number;
    destination: string;
    departureDate: string;
    image: string;
  };
}

const { trip } = Astro.props;
---

<Card className="overflow-hidden">
  <div class="h-48 w-full">
    <img src={trip.image} alt={trip.title} class="h-full w-full object-cover" loading="lazy" />
  </div>
  <div class="mt-6 space-y-3">
    <div class="flex items-center justify-between">
      <h3 class="text-xl font-semibold">{trip.title}</h3>
      <span class="text-sm text-text-secondary">{trip.destination}</span>
    </div>
    <p class="text-text-secondary">{trip.description}</p>
    <div class="grid grid-cols-2 gap-4 text-sm text-text-secondary">
      <span>Duration: {trip.durationDays} days</span>
      <span>Seats: {trip.seats}</span>
      <span>Departure: {trip.departureDate}</span>
    </div>
    <div class="flex items-center justify-between pt-4">
      <span class="text-xl font-semibold text-primary">${trip.price}</span>
      <BookingButton itemType="trip" itemId={trip.id} label="Reserve Spot" />
    </div>
  </div>
</Card>
