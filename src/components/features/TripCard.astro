---
import Card from '../ui/Card.astro';
import PayPalButton from '../ui/PayPalButton.astro';
import type { Trip } from '../../types';

interface Props {
  trip: Trip;
}

const { trip } = Astro.props;
---

<Card>
  <img src={trip.image} alt={trip.title} class="w-full h-48 object-cover rounded-t-lg" loading="lazy" />
  <div class="p-6">
    <h3 class="text-xl font-semibold text-primary mb-2">{trip.title}</h3>
    <p class="text-text-secondary text-sm mb-4">{trip.description}</p>
    <div class="flex flex-col gap-2 text-sm text-text-secondary mb-4 pb-4 border-b border-ocean-muted/10">
      <span>Duration: {trip.duration}</span>
      <span>Seats: {trip.seats}</span>
      <span>Departure: {trip.departureDate}</span>
    </div>
    <div class="flex items-center justify-between pt-4">
      <span class="text-xl font-semibold text-primary">${trip.price}</span>
      <PayPalButton 
        price={trip.price.toString()}
        currency="USD"
        productName={trip.title}
        itemId={trip.id}
        itemType="trip"
        priceLabel="Book Now"
      />
    </div>
  </div>
</Card>