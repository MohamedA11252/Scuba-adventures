---
interface Props {
    type?: 'text' | 'email' | 'password' | 'number';
    name: string;
    id: string;
    placeholder?: string;
    value?: string;
    required?: boolean;
    className?: string;
}

const { type = 'text', name, id, placeholder, value, required = false, className } = Astro.props;

const classes = `w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-secondary focus:border-secondary transition-colors ${className}`;
---

<input type={type} name={name} id={id} placeholder={placeholder} value={value} required={required} class={classes} />
