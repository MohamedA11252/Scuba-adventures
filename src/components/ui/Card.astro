---
interface Props {
    className?: string;
    padding?: 'sm' | 'md' | 'lg';
}

const { className, padding = 'md' } = Astro.props;

const paddingClasses = {
    sm: 'p-4',
    md: 'p-6',
    lg: 'p-8',
}

const classes = `bg-surface rounded-xl shadow-premium transition-all hover:shadow-lg ${paddingClasses[padding]} ${className}`;
---

<div class={classes}>
    <slot />
</div>
